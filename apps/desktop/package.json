{
  "name": "livefake",
  "private": true,
  "version": "0.0.71",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run_e2e.ps1",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node -e \"const fs=require('fs');const src='../../target/release/livefake.exe';const dst='../../livefake.exe';fs.copyFileSync(src,dst);console.log('copied: livefake.exe → LiveFakeTauri2/livefake.exe');\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.3.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.58.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
